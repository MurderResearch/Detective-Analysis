# ===== Facebook Page =====
# 長效 Page Access Token 和 Page ID，取得方式見 README
FB_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token
FB_PAGE_ID=your_page_id
FB_GRAPH_VERSION=v20.0

# ===== LLM provider =====
LLM_PROVIDER=anthropic          # anthropic 或 openai

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# ===== Bot 行為 =====
BOT_PERSONA=你是一個親切、專業的粉專小編，用繁體中文簡短回覆，必要時引導客戶私訊詳談。
MAX_REPLY_CHARS=280
# 留言符合這些關鍵字才回覆（空字串=全部都回）；逗號分隔
REPLY_KEYWORDS=

# ===== Poller =====
# watch 模式的間隔（分鐘）；one-shot 模式不會看這個
INTERVAL_MINUTES=60
# 往回抓多少小時內的貼文
LOOKBACK_HOURS=24
POST_LIMIT=10
CONVERSATION_LIMIT=20

# ===== State 持久化 =====
# 已回覆 ID 存哪
STATE_FILE=./.fb-reply-bot-state.json
STATE_TTL_DAYS=30
