<?xml version="1.0" encoding="UTF-8"?>
<!--
  macOS launchd plist 模板（fb-reply-bot）。
  每 3600 秒（1 小時）跑一次 `node src/index.js`。

  這是「模板」：裡面的 __NODE_BIN__ 和 __PROJECT_DIR__ 會由 install-launchd.sh
  在安裝時自動替換成實際路徑。你也可以手動用 sed 改完再複製到
  ~/Library/LaunchAgents/ ，但建議直接用 install-launchd.sh。
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.user.fbreplybot</string>

  <key>ProgramArguments</key>
  <array>
    <string>__NODE_BIN__</string>
    <string>__PROJECT_DIR__/src/index.js</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__PROJECT_DIR__</string>

  <key>StartInterval</key>
  <integer>1200</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>__PROJECT_DIR__/logs/bot.log</string>

  <key>StandardErrorPath</key>
  <string>__PROJECT_DIR__/logs/bot.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>__NODE_DIR__:/usr/local/bin:/usr/bin:/bin</string>
    <key>NODE_ENV</key>
    <string>production</string>
  </dict>
</dict>
</plist>
